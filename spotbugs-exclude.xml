<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

    <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2: Java records return field references directly.
         Our records (TranslationRequest, TranslationResponse) hold data from our own code
         or Jackson deserialization; callers do not mutate these lists. -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Class name="com.originspecs.specextractor.model.TranslationRequest"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Class name="com.originspecs.specextractor.model.TranslationResponse"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Class name="com.originspecs.specextractor.model.SpecRecord"/>
    </Match>

    <!-- Orchestrator: injected dependencies (reader, writer, etc.) are not "exposed" mutable state. -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="com.originspecs.specextractor.orchestration.Orchestrator"/>
    </Match>
</FindBugsFilter>
